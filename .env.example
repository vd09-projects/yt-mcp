# Example env file for yt-upload-mcp / yt-authorize.
#
# Copy this to a gitignored path — one file per channel is the intended model,
# e.g. env/shorts.env, env/main.env — fill in the real values, and point the
# binary at it:
#
#   ./bin/yt-authorize   --config config.json --channel shorts --env-file env/shorts.env
#   ./bin/yt-upload-mcp  --config config.json --env-file env/shorts.env
#
# PLACEHOLDER VALUES ONLY in this tracked file. NEVER commit real secrets.
# The loader uses file-wins precedence: values here override the shell env.
# chmod 600 your real env files — the loader warns if they are world-readable.

# Shared OAuth client (same GCP project for every channel).
YT_CLIENT_ID=your-client-id.apps.googleusercontent.com
YT_CLIENT_SECRET=your-client-secret

# Per-channel token FILE PATH (not the secret). The alias (SHORTS/MAIN) must
# match the ${YT_TOKEN_FILE_*} referenced by that channel block in config.json.
# yt-authorize --channel <alias> writes the token JSON to this path; the server
# reads it. The path points at the secret; the secret never lives in this file.
# Prefer an absolute path for a deployed server (a relative path resolves
# against the process working directory).
YT_TOKEN_FILE_SHORTS=state/shorts.token.json
# YT_TOKEN_FILE_MAIN=state/main.token.json
