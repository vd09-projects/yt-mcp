{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {},
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git init)",
      "Bash(ls:*)",
      "Bash(pwd)",
      "Bash(cat:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(tree:*)",
      "Bash(node --version)",
      "Bash(go version)",
      "Bash(go build:*)",
      "Bash(go test:*)",
      "Bash(go vet:*)",
      "Bash(go run:*)",
      "Bash(go mod:*)",
      "Bash(go list:*)",
      "Bash(gofmt:*)",
      "Bash(golangci-lint:*)",
      "Bash(npm --version)",
      "Bash(pnpm --version)",
      "Bash(npx vite:*)",
      "Bash(ffprobe:*)",
      "Bash(file:*)",
      "Bash(gh issue:*)",
      "Bash(gh label:*)",
      "Bash(gh repo view:*)",
      "Bash(gh api:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Bash(git checkout --:*)"
    ]
  },
  "hooks": {},
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true
  }
}
